APP_HOST=127.0.0.1
APP_PORT=3080
APP_DATA_MODE=filemaker
APP_ALLOW_MOCK_FALLBACK=false
APP_DEFAULT_ROLE=operator
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info

FILEMAKER_SERVER=https://your-filemaker-host
FILEMAKER_BASE_URL=
FILEMAKER_DATABASE=<FILEMAKER_DATABASE>
FILEMAKER_USERNAME=<FILEMAKER_USERNAME>
FILEMAKER_PASSWORD=<FILEMAKER_PASSWORD>
FILEMAKER_VERIFY_SSL=true
FILEMAKER_TIMEOUT_MS=15000
FILEMAKER_MAX_RETRIES=1
FILEMAKER_LAYOUT_REQUESTS=<REQUESTS_LAYOUT_NAME>
FILEMAKER_LAYOUT_RECORDS=<RECORDS_LAYOUT_NAME>
FILEMAKER_LAYOUT_SESSIONS=<SESSIONS_LAYOUT_NAME>
FILEMAKER_RECORD_FIELD_ID=<RECORD_ID_FIELD>
FILEMAKER_RECORD_FIELD_DISPLAY=<RECORD_DISPLAY_FIELD>
FILEMAKER_RECORD_FIELD_STATUS=<RECORD_STATUS_FIELD>
FILEMAKER_RECORD_FIELD_LOCATION=<RECORD_LOCATION_FIELD>
FILEMAKER_CONTAINER_SUPPORTING_PDF=<SUPPORTING_CONTAINER_FIELD>
FILEMAKER_SCHEMA_FILE=./config/filemaker-schema.example.json

# Optional smoke-test guard for filemaker mutation flows
FILEMAKER_ENABLE_MUTATION_SMOKE=false

# Optional deployment readiness script overrides
CHECK_READY_BASE_URL=http://127.0.0.1:3080
CHECK_READY_ROLE=admin
