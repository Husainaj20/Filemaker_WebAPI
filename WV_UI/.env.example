APP_HOST=127.0.0.1
APP_PORT=3080
APP_DATA_MODE=filemaker
APP_ALLOW_MOCK_FALLBACK=false
LOG_LEVEL=info

FILEMAKER_SERVER=https://your-filemaker-host
FILEMAKER_BASE_URL=
FILEMAKER_DATABASE=ExcessLand
FILEMAKER_USERNAME=web_api_user
FILEMAKER_PASSWORD=change-me
FILEMAKER_VERIFY_SSL=true
FILEMAKER_TIMEOUT_MS=15000
FILEMAKER_MAX_RETRIES=1
FILEMAKER_LAYOUT_REQUESTS=ExcessLandRequests
FILEMAKER_LAYOUT_RECORDS=
FILEMAKER_LAYOUT_SESSIONS=
FILEMAKER_RECORD_FIELD_ID=MainRecordId
FILEMAKER_RECORD_FIELD_DISPLAY=RecordLabel
FILEMAKER_RECORD_FIELD_STATUS=
FILEMAKER_RECORD_FIELD_LOCATION=
FILEMAKER_CONTAINER_SUPPORTING_PDF=viewPDF
FILEMAKER_SCHEMA_FILE=./config/filemaker-schema.example.json

# Optional smoke-test guard for filemaker mutation flows
FILEMAKER_ENABLE_MUTATION_SMOKE=false
